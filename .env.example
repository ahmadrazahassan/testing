# Firebase Web SDK (Project settings → General → Your apps → SDK setup and configuration)
# Copy this file to `.env` in the project root and fill in real values.
# Vite only exposes variables prefixed with VITE_ to client code.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional — only if Google Analytics is enabled for this web app (measurementId in console config)
# VITE_FIREBASE_MEASUREMENT_ID=
